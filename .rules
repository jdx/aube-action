project:
  name: aube-action
  kind: GitHub Action (composite)
  language: bash + YAML
  deliverable: action.yml at repo root, consumed as jdx/aube-action@vN

layout:
  action: action.yml (composite; steps -- install aube, verify, install Node via mise [optional], run aube install [optional])
  tests: .github/workflows/test.yml (matrix: ubuntu-latest, ubuntu-24.04-arm, macos-latest, windows-latest x 7 scenarios)
  release: .github/workflows/release-please.yml (googleapis/release-please-action; opens release PR with version bump + CHANGELOG; on merge, tags + creates GitHub release; major-tag job fast-forwards vN)
  pr_lint: .github/workflows/semantic-pr-lint.yml (validates PR title type via amannn/action-semantic-pull-request)
  changelog: CHANGELOG.md (regenerated by release-please from conventional commits -- never hand-edit)
  release_config: release-please-config.json + .release-please-manifest.json

support:
  issues_disabled: true
  channel: https://github.com/endevco/aube/discussions
  doc_phrasing: link Discussions, never "file an issue" or "open an issue"

github_interactions:
  comments: include attribution naming the AI assistant
  examples[2]:
    - "*This comment was generated by Codex.*"
    - "*This comment was generated by Claude.*"

commits:
  format: <type>(<scope>): <description>
  style: conventional commits -- lowercase after colon, imperative mood, concise
  enforced_by: semantic-pr-lint validates PR title; squash-merge propagates it to main as the commit subject
  consumed_by: release-please (commit type drives bump: feat -> minor, fix -> patch, BREAKING CHANGE / `!` -> major; type also drives CHANGELOG section)
  types[12]: fix, feat, refactor, chore, docs, style, test, perf, build, ci, revert, security
  scope_optional: true
  forbidden[2]:
    - "[codex]" or tool-branding prefix in subject
    - emoji in commit subject

ci_security:
  pat_secret: RELEASE_PLEASE_TOKEN
  pat_perms: contents:write + pull-requests:write (fine-grained, repo-scoped)
  pat_reason: GITHUB_TOKEN-opened PRs do not trigger downstream workflows; the PAT lets the release PR run test.yml on itself before merge
  third_party_actions: pinned to commit SHA with `# vN` trailer (org policy)

testing:
  scenarios[7]: default install, pinned aube version, explicit node-version, auto via mise.toml, auto via .nvmrc, error path on empty workspace, run-install end-to-end against fixture package.json
  fixtures: built inline in test workflow (mise.toml / .nvmrc / package.json)

forbidden[3]:
  - hand-editing CHANGELOG.md or .release-please-manifest.json (release-please regenerates them)
  - amending merged commits (always create a new commit)
  - third-party action references like @v4 (must be @<sha> # vN)
